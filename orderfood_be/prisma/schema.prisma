generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  VENDOR
  STUDENT
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role
  createdAt    DateTime @default(now())
  vendor       Vendor?
  student      Student?
  admin        Admin?
  devices      DeviceToken[]
  notifications Notification[]
}

model Admin {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  name      String
  createdAt DateTime @default(now())
}

model Vendor {
  id               String           @id @default(uuid())
  userId           String           @unique
  user             User             @relation(fields: [userId], references: [id])
  restaurantName   String
  description      String?
  createdAt        DateTime         @default(now())
  menuItems        MenuItem[]
  orders           Order[]
  revenueEntries   RevenueEntry[]
  revenueSummaries RevenueSummary[]
  balance          VendorBalance?
  settlements      VendorSettlement[]
}

model Student {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  name      String
  createdAt DateTime @default(now())
  orders    Order[]
}

model MenuItem {
  id           String      @id @default(uuid())
  vendorId     String
  vendor       Vendor      @relation(fields: [vendorId], references: [id])
  name         String
  description  String?
  priceInPaise Int
  imageUrl     String?
  isAvailable  Boolean     @default(true)
  category     String?
  sortOrder    Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  orderItems   OrderItem[]
}

model Order {
  id                 String        @id @default(uuid())
  studentId          String
  student            Student       @relation(fields: [studentId], references: [id])
  vendorId           String
  vendor             Vendor        @relation(fields: [vendorId], references: [id])
  status             OrderStatus   @default(PENDING)
  paymentStatus      PaymentStatus @default(PENDING)
  totalAmountInPaise Int
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  items              OrderItem[]
  revenueEntry       RevenueEntry?
  payment            Payment?
}

// --- Payment Module (isolated) ---

model Payment {
  id                String        @id @default(uuid())
  orderId           String        @unique
  order             Order         @relation(fields: [orderId], references: [id])
  amountInPaise     Int
  commissionInPaise Int           @default(0)
  vendorAmountInPaise Int         @default(0)
  status            PaymentStatus @default(PENDING)
  qrCodeData        String
  upiId             String?
  transactionId     String?
  paidAt            DateTime?
  expiresAt         DateTime
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model OrderItem {
  id                  String   @id @default(uuid())
  orderId             String
  order               Order    @relation(fields: [orderId], references: [id])
  menuItemId          String
  menuItem            MenuItem @relation(fields: [menuItemId], references: [id])
  quantity            Int
  priceAtOrderInPaise Int
}

model SduiLayout {
  id         String   @id @default(uuid())
  screenName String
  role       Role
  layoutJson Json
  version    Int      @default(1)
  updatedAt  DateTime @updatedAt

  @@unique([screenName, role])
}

// --- Revenue Module (isolated) ---

model RevenueEntry {
  id                 String   @id @default(uuid())
  vendorId           String
  vendor             Vendor   @relation(fields: [vendorId], references: [id])
  orderId            String   @unique
  order              Order    @relation(fields: [orderId], references: [id])
  grossAmountInPaise Int
  commissionInPaise  Int      @default(0)
  netAmountInPaise   Int
  currency           String   @default("INR")
  createdAt          DateTime @default(now())
}

model RevenueSummary {
  id                     String   @id @default(uuid())
  vendorId               String
  vendor                 Vendor   @relation(fields: [vendorId], references: [id])
  date                   DateTime @db.Date
  totalOrderCount        Int      @default(0)
  grossRevenueInPaise    Int      @default(0)
  totalCommissionInPaise Int      @default(0)
  netRevenueInPaise      Int      @default(0)
  currency               String   @default("INR")
  updatedAt              DateTime @updatedAt

  @@unique([vendorId, date])
}

// --- Commission/Escrow Module (isolated) ---

model PlatformConfig {
  id                    String   @id @default(uuid())
  key                   String   @unique
  value                 String
  description           String?
  updatedAt             DateTime @updatedAt
}

model VendorBalance {
  id                    String   @id @default(uuid())
  vendorId              String   @unique
  vendor                Vendor   @relation(fields: [vendorId], references: [id])
  pendingAmountInPaise  Int      @default(0)
  settledAmountInPaise  Int      @default(0)
  lastSettlementAt      DateTime?
  updatedAt             DateTime @updatedAt
}

enum SettlementStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model VendorSettlement {
  id              String           @id @default(uuid())
  vendorId        String
  vendor          Vendor           @relation(fields: [vendorId], references: [id])
  amountInPaise   Int
  status          SettlementStatus @default(PENDING)
  referenceId     String?
  notes           String?
  processedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([vendorId, status])
}

// --- Notification Module (isolated) ---

enum NotificationType {
  ORDER_PLACED
  ORDER_CONFIRMED
  ORDER_PREPARING
  ORDER_READY
  ORDER_CANCELLED
  ITEM_OUT_OF_STOCK
  ITEM_BACK_IN_STOCK
  PAYMENT_RECEIVED
  PAYMENT_FAILED
  GENERAL
}

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String
  platform  String   @default("android")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, token])
  @@index([userId])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}
